{
  "name": "memento",
  "version": "0.1.0",
  "private": true,
  "description": "Universal session adapter + memory MCP for AI coding agents",
  "license": "MIT",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x biome check .",
    "format": "bun x biome format --write .",
    "example:list": "bun run examples/list-all.ts",
    "example:ask": "bun run examples/ask-agents.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
