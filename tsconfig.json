{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@mneme/session-core": ["./packages/session-core/src/index.ts"],
      "@mneme/session-core/*": ["./packages/session-core/src/*"]
    }
  },
  "include": [
    "packages/*/src/**/*",
    "packages/*/test/**/*",
    "examples/**/*"
  ]
}
